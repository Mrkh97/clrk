{
  "name": "clrk-api",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "test": "tsx --test src/**/*.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "seed:receipts": "tsx src/scripts/seed-receipts.ts",
    "seed:receipts:apply": "tsx src/scripts/seed-receipts.ts --apply",
    "seed:optimizer": "tsx src/scripts/seed-optimizer-receipts.ts",
    "seed:optimizer:apply": "tsx src/scripts/seed-optimizer-receipts.ts --apply",
    "start": "node dist/src/index.js"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@date-fns/utc": "^2.1.1",
    "@hono/node-server": "^1.19.12",
    "ai": "^6.0.162",
    "better-auth": "^1.6.4",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.11",
    "postgres": "^3.4.9",
    "redis": "^5.12.1",
    "resend": "^6.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "drizzle-kit": "^0.31.10",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
